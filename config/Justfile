# Habita Infrastructure
#
# Environment-agnostic: same commands on laptop and production box.
# bin/ scripts detect environment automatically.

# First-run: create network, volumes, symlinks, secrets, start all
[group('infra')]
setup:
  ./bin/setup

# Start all services in dependency order
[group('infra')]
up:
  ./bin/up

# Stop all services
[group('infra')]
down:
  ./bin/down

# Deploy services — no args deploys all (e.g., just deploy, just deploy app api)
[group('infra')]
deploy *services:
  ./bin/deploy {{services}}

# Build and push image to DockerHub (svelte, go, consumer)
[group('infra')]
build service:
  ./bin/build {{service}}

# Rollback a service (e.g., just rollback app, just rollback app v1.2.3)
[group('infra')]
rollback service version="":
  ./bin/rollback {{service}} {{version}}

# Show all services with status, image, health
[group('infra')]
ps:
  ./bin/ps

# Follow logs for a service (svelte, db, kv, go, caddy, etc.)
[group('infra')]
logs service:
  ./bin/logs {{service}}

# Exec into a running container (e.g., just exec svelte sh)
[group('infra')]
exec service +cmd:
  ./bin/exec {{service}} {{cmd}}

# Restart a service (e.g., just restart svelte)
[group('infra')]
restart service:
  ./bin/restart {{service}}

# Recreate a service with latest config (e.g., just reload svelte)
[group('infra')]
reload service:
  ./bin/reload {{service}}

# Rebuild a service with fresh dependencies (e.g., just rebuild svelte)
[group('infra')]
rebuild service:
  ./bin/rebuild {{service}}

# Decrypt and write .env file
[group('infra')]
env-push:
  ./bin/env-push

# Compare local .env vs encrypted .env.enc
[group('infra')]
env-diff:
  ./bin/env-diff

# Prevent concurrent deploys
[group('infra')]
lock:
  ./bin/lock

# Release deploy lock
[group('infra')]
unlock:
  ./bin/unlock

# Show unhealthy containers and why
[group('infra')]
health:
  ./bin/health

# Show recent deploy history
[group('infra')]
audit:
  ./bin/audit

# Remove unused images, containers, volumes
[group('infra')]
prune:
  ./bin/prune

# Tear down + rebuild all stacks, verify health
[group('infra')]
test-infra:
  ./bin/test-infra

[group('project')]
mod observability

[group('project')]
mod db

[group('project')]
mod lint

[group('project')]
mod test

[group('project')]
mod zone

[group('project')]
mod ssh
