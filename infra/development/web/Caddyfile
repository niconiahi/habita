dev.habita.rent {
  tls /etc/ssl/certs/dev.habita.rent.pem /etc/ssl/private/dev.habita.rent-key.pem

  handle /image/* {
    uri strip_prefix /image
    reverse_proxy image:8080
  }

  handle /nominatim/* {
    uri strip_prefix /nominatim
    reverse_proxy nominatim:8080
  }

  # SvelteKit app (wev) - all /wev/* routes and assets
  handle /wev/* {
    reverse_proxy wev:5174
  }
  handle /wev {
    reverse_proxy wev:5174
  }

  reverse_proxy web:5173
}
