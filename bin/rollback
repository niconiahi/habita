#!/usr/bin/env bash
source "$(dirname "$0")/lib.sh"

[[ $# -lt 1 ]] && { echo "Usage: just rollback <service> [image]"; exit 1; }

service="$1"
image="${2:-}"

if [[ -n "$image" ]]; then
  echo "rolling back $service to image: $image"
  case "$service" in
    app)      SVELTE_IMAGE="$image" compose app up -d --force-recreate svelte ;;
    api)      GO_IMAGE="$image" compose api up -d --force-recreate go ;;
    consumer) BROKER_IMAGE="$image" compose consumer up -d --force-recreate ;;
    *)        echo "image rollback only supports app, api, consumer"; exit 1 ;;
  esac
else
  echo "rolling back $service to previous git state"
  git revert --no-commit HEAD
  "$REPO_ROOT/bin/deploy" "$service"
  echo "revert applied but not committed. review with 'git diff'"
fi
