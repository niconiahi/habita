#!/usr/bin/env bash
source "$(dirname "$0")/lib.sh"

[[ $# -lt 1 ]] && { echo "Usage: just restart <service>"; exit 1; }

service="$1"

for compose_file in "$INFRA"/*/docker-compose.yml; do
  if grep -q "^  ${service}:" "$compose_file" 2>/dev/null; then
    stack=$(basename "$(dirname "$compose_file")")
    compose "$stack" restart "$service"
    exit 0
  fi
done

echo "unknown service: $service"
exit 1
