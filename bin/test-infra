#!/usr/bin/env bash
source "$(dirname "$0")/lib.sh"

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

log_ok() { echo -e "${GREEN}✓${NC} $1"; }
log_fail() { echo -e "${RED}✗${NC} $1"; }
log_info() { echo -e "${YELLOW}→${NC} $1"; }

cd "$REPO_ROOT"

echo ""
echo "=== testing habita infrastructure ==="
echo ""

log_info "stopping existing containers"
"$REPO_ROOT/bin/down"

log_info "creating network + volumes"
docker network create internal 2>/dev/null || true
docker volume create backups 2>/dev/null || true
log_ok "network ready"

log_info "starting storage"
compose storage up -d
log_info "waiting for db"
wait_healthy database 60 && log_ok "db is healthy" || { log_fail "db failed"; exit 1; }
log_info "waiting for kv"
wait_healthy cache 60 && log_ok "kv is healthy" || { log_fail "kv failed"; exit 1; }

log_info "starting app"
compose app up -d
sleep 5
docker ps --filter "name=app-svelte-1" --format "{{.Status}}" | grep -q "Up" && log_ok "svelte running" || { log_fail "svelte failed"; exit 1; }

log_info "starting api"
compose api up -d
wait_healthy "" 60 && log_ok "go healthy" || log_info "go still starting (no habita.role label match)"

log_info "starting media"
compose media up -d
sleep 5
log_ok "media started"

log_info "starting gateway"
compose gateway up -d
sleep 3
docker ps --filter "name=gateway-caddy-1" --format "{{.Status}}" | grep -q "Up" && log_ok "caddy running" || { log_fail "caddy failed"; exit 1; }

log_info "starting scheduler"
compose scheduler up -d
sleep 2
docker ps --filter "name=scheduler-ofelia-1" --format "{{.Status}}" | grep -q "Up" && log_ok "ofelia running" || { log_fail "ofelia failed"; exit 1; }

echo ""
echo "=== summary ==="
echo ""
log_ok "storage (db, kv, object)"
log_ok "app     (svelte)"
log_ok "api     (go)"
log_ok "media   (image)"
log_ok "gateway (caddy)"
log_ok "scheduler (ofelia)"
echo ""
log_info "skipped: observability, geo, broker, consumer, pdf, status (optional)"
echo ""
echo "to stop everything: just down"
