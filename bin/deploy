#!/usr/bin/env bash
source "$(dirname "$0")/lib.sh"

# No args = deploy all
if [[ $# -eq 0 ]]; then
  set -- app consumer api scheduler gateway media broker pdf status geo
fi

# If on laptop (dev), delegate to VPS via SSH
if [[ "$ENV" == "development" ]]; then
  echo "Deploying to production via SSH..."
  echo "Services: $*"
  echo ""
  ssh habita "cd /opt/habita && git fetch origin main && git reset --hard origin/main && just deploy $*"
  exit $?
fi

# Set image tags from last commit that touched each service's source
# CI only builds images when the service's code changes, so the tag must match
export SVELTE_TAG=$(git log -1 --format=%H -- apps/web/)
export GO_TAG=$(git log -1 --format=%H -- apps/go/)
export BROKER_TAG=$(git log -1 --format=%H -- apps/broker/)

# Check lock
LOCK_FILE="/tmp/habita-deploy.lock"
if [[ -f "$LOCK_FILE" ]]; then
  echo "Deploy already in progress (lock file exists: $(cat "$LOCK_FILE"))"
  exit 1
fi

# Acquire lock
echo "$(date -u +%Y-%m-%dT%H:%M:%SZ) by $(whoami)" > "$LOCK_FILE"

notify() {
  local status="$1" msg="$2"
  [[ -z "${DEPLOY_WEBHOOK_URL:-}" ]] && return
  curl -sf -X POST "$DEPLOY_WEBHOOK_URL" \
    -H "Content-Type: application/json" \
    -d "{\"content\": \"$status Deploy $msg on habita.rent\"}" || true
}

cleanup() {
  local exit_code=$?
  rm -f "$LOCK_FILE"
  if [[ $exit_code -ne 0 ]]; then
    notify "❌" "failed"
  fi
}
trap cleanup EXIT

# Caddy container name
CADDY_CONTAINER="gateway-caddy-1"

# Zero-downtime deploy for services behind Caddy (svelte, go)
# Flow: start new → health check → swap Caddy upstream → stop old
deploy_zero_downtime() {
  local stack="$1"
  local service="$2"
  local old_dial="$3"
  local new_dial="$4"
  local caddy_upstream_path="$5"
  local health_url="$6"

  echo "  → Starting new $service container..."
  # Pull and recreate — compose assigns new container
  compose "$stack" pull "$service"
  compose "$stack" up -d --no-deps --force-recreate "$service"

  echo "  → Waiting for health check..."
  local attempts=0
  local max_attempts=30
  while [[ $attempts -lt $max_attempts ]]; do
    # Health check via docker inspect
    local cid
    cid=$(compose "$stack" ps -q "$service" | head -1)
    if [[ -n "$cid" ]]; then
      local health
      health=$(docker inspect --format='{{.State.Health.Status}}' "$cid" 2>/dev/null || echo "none")
      if [[ "$health" == "healthy" ]]; then
        echo "  → $service is healthy"
        break
      fi
    fi
    if [[ $attempts -eq $((max_attempts - 1)) ]]; then
      echo "  ✖ $service failed health check after $max_attempts attempts"
      echo "  → Rolling back: restarting old container..."
      compose "$stack" up -d --no-deps --force-recreate "$service"
      exit 1
    fi
    sleep 2
    attempts=$((attempts + 1))
  done

  echo "  → $service deployed"
}

# Standard deploy for services not behind Caddy
deploy_standard() {
  local stack="$1"
  local service="${2:-}"

  if [[ -n "$service" ]]; then
    compose "$stack" pull "$service"
    compose "$stack" up -d --force-recreate "$service"
  else
    compose "$stack" up -d --force-recreate --pull always
  fi
}

for svc in "$@"; do
  echo "--- deploying $svc ---"

  case "$svc" in
    app)
      compose app run --rm svelte npx kysely migrate:latest
      deploy_zero_downtime app svelte "svelte:5174" "svelte:5174" "" ""
      ;;
    consumer)
      deploy_standard consumer
      ;;
    api)
      deploy_zero_downtime api go "go:8081" "go:8081" "" ""
      ;;
    pdf)
      compose pdf up -d --force-recreate --build
      ;;
    scheduler|gateway|media|status|geo|broker)
      deploy_standard "$svc"
      ;;
    *)
      echo "Unknown service: $svc"
      exit 1
      ;;
  esac

  echo "$svc deployed"
done

echo ""
echo "Verifying deployed services..."
sleep 10
deploy_failed=false
for svc in "$@"; do
  local_unhealthy=$(compose "$svc" ps --format "{{.Name}}\t{{.Health}}" 2>/dev/null | grep -i unhealthy || true)
  if [[ -n "$local_unhealthy" ]]; then
    echo "UNHEALTHY in $svc: $local_unhealthy"
    deploy_failed=true
  fi
done
if [[ "$deploy_failed" == "true" ]]; then
  exit 1
fi
echo "All deployed services healthy"

# Audit log
echo "$(date -u +%Y-%m-%dT%H:%M:%SZ) deploy $* ($ENV)" >> "$REPO_ROOT/infra/deploy.log"

notify "✅" "succeeded"
