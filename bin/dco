#!/usr/bin/env bash
set -euo pipefail

REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
INFRA_DIR="$REPO_ROOT/infra/development"

stack="$1"
shift

case "$stack" in
  app|gateway|api|media|geo|scheduler)
    docker compose -p "$stack" -f "$INFRA_DIR/$stack/docker-compose.yml" "$@"
    ;;
  obs|observability)
    docker compose -p observability -f "$INFRA_DIR/observability/docker-compose.yml" "$@"
    ;;
  *)
    echo "Unknown stack: $stack"
    echo "Available: app, gateway, api, media, geo, scheduler, obs"
    exit 1
    ;;
esac
