#!/usr/bin/env bash
set -euo pipefail

REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
if [ "$REPO_ROOT" = "/opt/habita" ]; then
  INFRA_DIR="$REPO_ROOT/infra/production"
else
  INFRA_DIR="$REPO_ROOT/infra/development"
fi

stack="$1"
service="$2"
shift 2
subcommand="$1"
shift

# Separate flags (start with -) from positional args
flags=()
args=()
for arg in "$@"; do
  if [[ "$arg" == -* ]]; then
    flags+=("$arg")
  else
    args+=("$arg")
  fi
done

ENV_FILE=""
if [ -f "$INFRA_DIR/versions.env" ]; then
  ENV_FILE="--env-file $INFRA_DIR/versions.env"
fi

case "$stack" in
  app|gateway|api|media|geo|scheduler)
    docker compose -p "$stack" $ENV_FILE -f "$INFRA_DIR/$stack/docker-compose.yml" "$subcommand" "${flags[@]+"${flags[@]}"}" "$service" "${args[@]+"${args[@]}"}"
    ;;
  obs|observability)
    docker compose -p observability $ENV_FILE -f "$INFRA_DIR/observability/docker-compose.yml" "$subcommand" "${flags[@]+"${flags[@]}"}" "$service" "${args[@]+"${args[@]}"}"
    ;;
  *)
    echo "Unknown stack: $stack"
    echo "Available: app, gateway, api, media, geo, scheduler, obs"
    exit 1
    ;;
esac
