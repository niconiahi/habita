#!/usr/bin/env bash
set -euo pipefail

REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
if [ "$REPO_ROOT" = "/opt/habita" ]; then
  INFRA_DIR="$REPO_ROOT/infra/production"
else
  INFRA_DIR="$REPO_ROOT/infra/development"
fi

SUBCOMMANDS="up|down|logs|exec|run|build|pull|push|restart|stop|start|ps|top|config|create|rm|kill|pause|unpause|port|events|images|version"

stack="$1"
shift

# If the next arg is a subcommand, this is a stack-level command (no service)
if [[ "$1" =~ ^($SUBCOMMANDS)$ ]]; then
  service=""
  subcommand="$1"
  shift
else
  service="$1"
  shift
  subcommand="$1"
  shift
fi

# Separate flags (start with -) from positional args
flags=()
args=()
for arg in "$@"; do
  if [[ "$arg" == -* ]]; then
    flags+=("$arg")
  else
    args+=("$arg")
  fi
done

ENV_FILE=""
if [ -f "$INFRA_DIR/versions.env" ]; then
  ENV_FILE="--env-file $INFRA_DIR/versions.env"
fi

case "$stack" in
  storage|app|gateway|api|media|geo|scheduler)
    docker compose -p "$stack" $ENV_FILE -f "$INFRA_DIR/$stack/docker-compose.yml" "$subcommand" "${flags[@]+"${flags[@]}"}" ${service:+"$service"} "${args[@]+"${args[@]}"}"
    ;;
  obs|observability)
    docker compose -p observability $ENV_FILE -f "$INFRA_DIR/observability/docker-compose.yml" "$subcommand" "${flags[@]+"${flags[@]}"}" ${service:+"$service"} "${args[@]+"${args[@]}"}"
    ;;
  *)
    echo "unknown stack: $stack"
    echo "available: storage, app, gateway, api, media, geo, scheduler, obs"
    exit 1
    ;;
esac
