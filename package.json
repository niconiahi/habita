{
  "name": "memudo",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "react-router build",
    "dev": "react-router dev",
    "up": "docker compose --file run/development/docker-compose.yml up --build",
    "down": "docker compose --file run/development/docker-compose.yml down --volumes --remove-orphans",
    "start": "react-router-serve ./build/server/index.js",
    "typecheck": "react-router typegen && tsc",
    "lint": "biome check .",
    "lint:fix": "biome check --write --unsafe .",
    "db:reset": "bun run db:migrate && bun run db:seed",
    "db:types": "bun run db/generate_types.mjs",
    "db:seed": "kysely seed:run",
    "db:migrate": "kysely migrate:latest",
    "format": "biome format --write ."
  },
  "dependencies": {
    "@node-rs/argon2": "^2.0.2",
    "@oslojs/crypto": "^1.0.1",
    "@oslojs/encoding": "^1.1.0",
    "@react-router/node": "^7.7.1",
    "@react-router/serve": "^7.7.1",
    "@types/pg": "^8.15.5",
    "isbot": "^5.1.27",
    "pg": "^8.16.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router": "^7.7.1",
    "valibot": "^1.1.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.1.1",
    "@react-router/dev": "^7.7.1",
    "@tailwindcss/vite": "^4.1.4",
    "@types/node": "^20",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "kysely": "^0.28.5",
    "kysely-codegen": "^0.18.5",
    "kysely-ctl": "^0.18.0",
    "tailwindcss": "^4.1.4",
    "typescript": "^5.8.3",
    "vite": "^6.3.3",
    "vite-tsconfig-paths": "^5.1.4"
  }
}
